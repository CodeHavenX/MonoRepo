# FlyerBoard Backend Environment Variables
# Copy this file to /etc/flyerboard/env and fill in your values.
# This file is referenced by the systemd service unit (flyerboard.service).
#
# Environment variable names are prefixed with FLYERBOARD_ because the application
# uses EnvironmentConfiguration with domain prefix "FLYERBOARD".
# Keys are transformed: dots and special characters → underscores, letters → uppercase.

# Supabase project URL (e.g. https://xyzcompany.supabase.co)
# Maps to setting key: supabase.url
FLYERBOARD_SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (NOT the anon key — the service role key bypasses RLS)
# Maps to setting key: supabase.key
FLYERBOARD_SUPABASE_KEY=your-service-role-key

# Port the Ktor backend listens on (default: 9292 if not set)
# This is read directly by Ktor HOCON — no FLYERBOARD_ prefix needed.
PORT=8080

# Maximum allowed file upload size in bytes (default: 10485760 = 10 MB)
# Maps to setting key: flyer.max_file_size_bytes
FLYERBOARD_FLYER_MAX_FILE_SIZE_BYTES=10485760
