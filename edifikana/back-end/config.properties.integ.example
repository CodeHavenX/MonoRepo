# Copy this file to config.properties.integ and fill in your local Supabase values.
# Run `supabase start` from edifikana/back-end/ to get these values.
#
# WARNING: config.properties.integ is git-ignored. Never commit real credentials.
supabase.url=http://127.0.0.1:54321
supabase.key=<your-local-anon-key>
supabase.disable=false
webapp.url=http://127.0.0.1:8080
